{
  "name": "renatobo/eventon-apify",
  "description": "Development quality tooling for the EventON APIfy WordPress plugin.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.0"
  },
  "require-dev": {
    "php-stubs/wordpress-stubs": "^6.8 || ^7.0",
    "phpstan/phpstan": "^2.1",
    "squizlabs/php_codesniffer": "^3.13",
    "wp-coding-standards/wpcs": "^3.2"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "sort-packages": true
  },
  "scripts": {
    "lint": "phpcs",
    "analyse": "phpstan analyse --no-progress --debug --memory-limit=1G",
    "test": "php tests/php/run.php",
    "coverage": "php scripts/coverage-gate.php",
    "performance": "php scripts/performance-gate.php",
    "quality": [
      "@lint",
      "@analyse",
      "@test",
      "@performance"
    ]
  }
}
