# Copy to .env.production.local and fill in real values.
# This file is safe to commit; .env.production.local is ignored.

EVENTON_APIFY_BASE_URL=https://example.com
EVENTON_APIFY_USERNAME=admin
EVENTON_APIFY_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
# Optional alternative for local/dev cookie auth:
# EVENTON_APIFY_PASSWORD=your-admin-password
EVENTON_APIFY_EVENT_ID=123
EVENTON_APIFY_DELTA_UPDATED_AFTER=2026-04-08T18:00:00Z
EVENTON_APIFY_DELTA_UPDATED_AFTER_ID=0
