            }
          },
          "event_subtitle": {
            "type": "string"
          },
          "event_excerpt": {
            "type": "string"
          },
          "link": {
            "type": "string",
            "format": "uri"
          },
          "start_timestamp": {
            "type": "integer"
          },
          "start_at": {
            "type": "string",
            "format": "date-time"
          },
          "start_date": {
            "type": "string",
            "format": "date"
          },
          "start_time": {
            "type": "string"
          },
          "event_start_timestamp": {
            "type": "integer"
          },
          "end_timestamp": {
            "type": "integer"
