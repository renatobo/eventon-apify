{
  "openapi": "3.1.0",
  "info": {
    "title": "EventON APIfy REST API",
    "summary": "OpenAPI definition for the public discovery routes and the administrator-protected EventON event endpoints.",
    "description": "EventON APIfy exposes a protected EventON CRUD API, optional RSVP reporting routes, and public MCP discovery documents. GitHub Releases is the primary distribution channel for this plugin, and Git Updater is the intended update mechanism for GitHub installs.",
    "version": "1.7.0"
  },
  "externalDocs": {
    "description": "Plugin repository",
    "url": "https://github.com/renatobo/eventon-apify"
  },
  "servers": [
    {
      "url": "{siteUrl}/wp-json",
      "description": "WordPress REST root",
      "variables": {
        "siteUrl": {
          "default": "https://example.com"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Discovery",
      "description": "Public discovery documents and MCP schema manifests."
    },
    {
      "name": "Events",
      "description": "Administrator-only EventON event CRUD routes."
    },
    {
      "name": "RSVP",
      "description": "Optional RSVP reporting routes when the EventON RSVP addon and matching API capabilities are enabled."
    }
  ],
  "paths": {
    "/eventonapify/v1/mcp-schema": {
      "get": {
        "tags": [
          "Discovery"
        ],
        "summary": "Get the full MCP schema manifest",
        "description": "Returns the public MCP discovery document for the published EventON content contracts.",
        "security": [],
        "responses": {
          "200": {
            "description": "Manifest envelope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/McpManifest"
                }
              }
            }
          }
        }
      }
    },
    "/eventonapify/v1/mcp-schema/{content_type}": {
      "get": {
        "tags": [
          "Discovery"
        ],
        "summary": "Get a single MCP content-type manifest",
        "description": "Returns the public MCP discovery document for a single published content type.",
        "security": [],
        "parameters": [
          {
            "name": "content_type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "ajde_events",
                "event_rsvps"
              ]
            },
            "description": "Published content type slug. `event_rsvps` is available only when the RSVP addon is active."
          }
        ],
        "responses": {
          "200": {
            "description": "Manifest envelope scoped to one content type",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/McpManifest"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/eventonapify/v1/events": {
      "get": {
        "tags": [
          "Events"
        ],
        "summary": "List EventON events",
        "description": "Returns a paginated collection of EventON events. Requires administrator authentication and the `list` API capability.",
        "security": [
          {
            "basicAuth": []
          }
        ],
        "parameters": [
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            },
            "description": "Number of events to return."
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            },
            "description": "Page number."
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string",
              "default": ""
            },
            "description": "Free-text search against the event post title and content."
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "default": ""
            },
            "description": "Comma-separated WordPress post statuses. Allowed values are `publish`, `draft`, `private`, `pending`, and `future`."
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated EventON events",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedEventsResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "403": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "500": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      },
      "post": {
        "tags": [
          "Events"
        ],
        "summary": "Create an EventON event",
        "description": "Creates a new `ajde_events` record. Requires administrator authentication and the `create` API capability.",
        "security": [
          {
            "basicAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EventCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created event",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Event"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "403": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "500": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/eventonapify/v1/events/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "integer",
            "minimum": 1
          },
          "description": "Event post ID."
        }
      ],
      "get": {
        "tags": [
          "Events"
        ],
        "summary": "Get one EventON event",
        "description": "Returns a single EventON event. Requires administrator authentication and the `read` API capability.",
        "security": [
          {
            "basicAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Event detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Event"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "403": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      },
      "put": {
        "tags": [
          "Events"
        ],
        "summary": "Replace or update an EventON event",
        "description": "Updates an existing `ajde_events` record. Requires administrator authentication and the `update` API capability.",
        "security": [
          {
            "basicAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EventUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated event",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Event"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "403": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      },
      "patch": {
        "tags": [
          "Events"
        ],
        "summary": "Partially update an EventON event",
        "description": "Applies a partial update to an existing `ajde_events` record. Requires administrator authentication and the `update` API capability.",
        "security": [
          {
            "basicAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EventUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated event",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Event"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "403": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      },
      "delete": {
        "tags": [
          "Events"
        ],
        "summary": "Trash an EventON event",
        "description": "Moves an EventON event to the WordPress trash. Requires administrator authentication and the `delete` API capability.",
        "security": [
          {
            "basicAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Deletion result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "403": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "500": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/eventonapify/v1/events/{id}/rsvps": {
      "get": {
        "tags": [
          "RSVP"
        ],
        "summary": "List RSVP attendees for an event",
        "description": "Returns paginated RSVP attendee records for an EventON event. Available only when the RSVP addon is active and the `rsvp_attendees` capability is enabled.",
        "security": [
          {
            "basicAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "description": "Event post ID."
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 50
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string",
              "default": ""
            },
            "description": "Free-text attendee search."
          },
          {
            "name": "rsvp",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "all",
                "yes",
                "no",
                "maybe"
              ],
              "default": "all"
            },
            "description": "RSVP response filter."
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "all"
            },
            "description": "Check-in status filter."
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated attendee list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RsvpAttendeeListResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "403": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/eventonapify/v1/events/{id}/rsvps/summary": {
      "get": {
        "tags": [
          "RSVP"
        ],
        "summary": "Get the RSVP summary for an event",
        "description": "Returns the yes-only RSVP totals for an EventON event. Available only when the RSVP addon is active and the `rsvp_counts` capability is enabled.",
        "security": [
          {
            "basicAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "description": "Event post ID."
          }
        ],
        "responses": {
          "200": {
            "description": "RSVP summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RsvpSummary"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "403": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    }
  },
  "components": {
    "responses": {
      "ErrorResponse": {
        "description": "Error response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Use a WordPress administrator username and an Application Password."
      }
    },
    "schemas": {
      "McpManifest": {
        "type": "object",
        "description": "Public MCP discovery document published by EventON APIfy.",
        "properties": {
          "schema_version": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "provider_version": {
            "type": "string"
          },
          "generated_at": {
            "type": "string",
            "format": "date-time"
          },
          "site_url": {
            "type": "string",
            "format": "uri"
          },
          "namespace": {
            "type": "string"
          },
          "discovery": {
            "type": "object",
            "properties": {
              "manifest": {
                "type": "string",
                "format": "uri"
              },
              "content_type_template": {
                "type": "string",
                "format": "uri"
              }
            }
          },
          "availability": {
            "type": "object",
            "additionalProperties": true
          },
          "content_types": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "example": {
          "schema_version": "1.0.0",
          "provider": "eventon-apify",
          "provider_version": "1.7.0",
          "generated_at": "2026-03-30T00:00:00Z",
          "site_url": "https://example.com",
          "namespace": "eventonapify/v1",
          "discovery": {
            "manifest": "https://example.com/wp-json/eventonapify/v1/mcp-schema",
            "content_type_template": "https://example.com/wp-json/eventonapify/v1/mcp-schema/{content_type}"
          },
          "availability": {
            "eventon_available": true,
            "custom_event_api_enabled": true,
            "wp_v2_compatibility_enabled": true
          },
          "content_types": {
            "ajde_events": {
              "slug": "ajde_events",
              "preferred_endpoint": "eventonapify/v1/events",
              "supported_operations": [
                "create",
                "update"
              ]
            }
          }
        }
      },
      "PaginatedEventsResponse": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer"
          },
          "pages": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "per_page": {
            "type": "integer"
          },
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Event"
            }
          }
        }
      },
      "EventCreateRequest": {
        "allOf": [
          {
            "$ref": "#/components/schemas/EventWriteRequest"
          },
          {
            "type": "object",
            "required": [
              "title"
            ]
          }
        ],
        "example": {
          "title": "Ride to Big Bear",
          "description": "Optional HTML content",
          "excerpt": "Ride to Big Bear is a one-day ride in Big Bear Lake on April 1, 2026 from 9:00 to 17:00 PT.",
          "status": "publish",
          "tags": [
            "bike night",
            "ducati"
          ],
