              "$ref": "#/components/schemas/Organizer"
            }
          },
          "event_color": {
            "type": "string"
          },
          "event_color_secondary": {
            "type": "string"
          },
          "learn_more_link": {
            "type": "string",
            "format": "uri"
          },
          "learn_more_link_target": {
            "type": "boolean"
          },
          "interaction": {
            "$ref": "#/components/schemas/Interaction"
          },
          "flags": {
            "$ref": "#/components/schemas/EventFlags"
          },
          "health": {
            "$ref": "#/components/schemas/Health"
          },
          "gradient_angle": {
            "type": "number"
          },
          "virtual": {
            "$ref": "#/components/schemas/VirtualEvent"
          },
          "repeat": {
            "$ref": "#/components/schemas/RepeatRule"
          },
          "related_events": {
            "$ref": "#/components/schemas/RelatedEvents"
          },
          "seo": {
            "$ref": "#/components/schemas/Seo"
          },
          "faqs": {
            "$ref": "#/components/schemas/Faqs"
          },
          "rsvp": {
            "$ref": "#/components/schemas/RsvpSettings"
          }
        },
        "example": {
          "status": "publish",
          "start_date": "2026-04-08",
          "start_time": "10:00",
          "end_date": "2026-04-08",
