      },
      "EventUpdateRequest": {
        "$ref": "#/components/schemas/EventWriteRequest"
      },
      "EventWriteRequest": {
        "type": "object",
        "description": "Preferred JSON payload for create and update requests. Nested EventON-style objects are preferred, while some legacy flat aliases remain supported by the plugin runtime.",
        "properties": {
