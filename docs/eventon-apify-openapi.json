            "type": "string",
            "enum": [
              "publish",
              "draft",
              "private",
              "pending",
              "future"
            ]
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "event_type": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "start_at": {
            "type": "string",
            "format": "date-time"
          },
          "start_date": {
            "type": "string",
            "format": "date"
          },
          "start_time": {
            "type": "string",
